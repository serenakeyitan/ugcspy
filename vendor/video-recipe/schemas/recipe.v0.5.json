{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/serenakeyitan/video-recipe/schemas/recipe.v0.5.json",
  "title": "video-recipe v0.5",
  "description": "Production blueprint pass. Adds per-cut caption (editorial overlay text distinct from OCR'd title cards), top-level hook block, top-level tts block, and reorders fields top-to-bottom as a make-this-video brief. Builds on v0.4.",
  "type": "object",
  "required": [
    "schema_version",
    "source_url",
    "video_id",
    "duration_sec",
    "generated_at",
    "cuts"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "0.5" },
    "source_url": { "type": "string", "format": "uri" },
    "video_id": { "type": "string", "minLength": 1 },
    "duration_sec": { "type": "number", "minimum": 0 },
    "resolution": { "type": ["string", "null"] },
    "fps": { "type": ["number", "null"] },
    "generated_at": { "type": "string", "format": "date-time" },

    "hook": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["duration_sec", "spans_cuts", "pattern"],
          "additionalProperties": false,
          "properties": {
            "duration_sec": { "type": "number", "minimum": 0 },
            "spans_cuts": {
              "type": "array",
              "items": { "type": "integer", "minimum": 0 }
            },
            "pattern": {
              "type": "string",
              "enum": [
                "question",
                "claim",
                "shock_cut",
                "transformation_tease",
                "pattern_break"
              ]
            },
            "text": { "type": ["string", "null"] },
            "voiceover": { "type": ["string", "null"] },
            "first_visual": { "type": ["string", "null"] }
          }
        }
      ]
    },

    "cuts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "index",
          "start_sec",
          "end_sec",
          "duration_sec",
          "keyframes",
          "inferred_kind"
        ],
        "additionalProperties": false,
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "start_sec": { "type": "number", "minimum": 0 },
          "end_sec": { "type": "number", "minimum": 0 },
          "duration_sec": { "type": "number", "minimum": 0 },
          "flagged_short": { "type": "boolean" },
          "keyframes": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": { "type": "string" }
          },
          "inferred_kind": {
            "type": "string",
            "enum": [
              "ai_clip",
              "title_card",
              "non_ai_footage",
              "lumped_cuts",
              "transition",
              "unreadable"
            ]
          },
          "inferred": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "required": [
                  "subject",
                  "action",
                  "setting",
                  "style",
                  "camera",
                  "lighting",
                  "duration_sec",
                  "aspect_ratio",
                  "prompt"
                ]
              }
            ]
          },
          "inferred_error": { "type": ["string", "null"] },
          "transcript": { "type": ["string", "null"] },
          "ocr_text": { "type": ["string", "null"] },
          "ocr_confidence": { "type": ["number", "null"] },
          "paired_prompt_text": { "type": ["string", "null"] },
          "caption": {
            "type": ["string", "null"],
            "description": "Editorial text overlay added in post-production (kinetic typography, hook overlay, lower-third, burned-in subtitle). Distinct from OCR'd title-card text (which is the cut's own content, not an overlay) and from scene text inside the AI-generated visual."
          }
        }
      }
    },

    "tts": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["script", "language", "duration_sec", "likely_synthetic"],
          "additionalProperties": false,
          "properties": {
            "script": { "type": "string" },
            "language": { "type": ["string", "null"] },
            "duration_sec": { "type": "number", "minimum": 0 },
            "likely_synthetic": { "type": "boolean" },
            "model": { "type": ["string", "null"] },
            "voice_id": { "type": ["string", "null"] },
            "evidence": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      ]
    },

    "audio": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["language", "transcript_path", "duration_sec"],
          "additionalProperties": false,
          "properties": {
            "language": { "type": ["string", "null"] },
            "transcript_path": { "type": "string" },
            "duration_sec": { "type": "number", "minimum": 0 }
          }
        }
      ]
    },

    "assembly": { "type": ["object", "null"] },
    "model_attribution": { "type": ["object", "null"] }
  }
}
